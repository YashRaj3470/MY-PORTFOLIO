<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>YASH RAJ - PORTFOLIO</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        :root{
            --bg: #07071a;
            --bg2: #0b0b2e;
            --text: #f4f4ff;
            --muted: rgba(244, 244, 255, 0.72);
            --card: rgba(255, 255, 255, 0.06);
            --border: rgba(255, 255, 255, 0.10);
            --shadow: 0 18px 50px rgba(0, 0, 0, 0.45);
            --accent: #a855f7;
            --accent2: #22d3ee;
        }

        [data-theme="light"]{
            --bg: #f7f7ff;
            --bg2: #ffffff;
            --text: #0b1020;
            --muted: rgba(11, 16, 32, 0.70);
            --card: rgba(11, 16, 32, 0.04);
            --border: rgba(11, 16, 32, 0.10);
            --shadow: 0 18px 50px rgba(11, 16, 32, 0.12);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        html { scroll-behavior: smooth; }
        body{
            min-height: 100dvh;
            background:
                radial-gradient(1200px 600px at 10% 0%, rgba(168, 85, 247, 0.25), transparent 60%),
                radial-gradient(1000px 600px at 90% 10%, rgba(34, 211, 238, 0.18), transparent 55%),
                linear-gradient(180deg, var(--bg), var(--bg2));
            color: var(--text);
            font-family: 'Poppins', sans-serif;
        }

        a{ color: inherit; text-decoration: none; }
        img{ max-width: 100%; display: block; }

        .container{ width: min(1100px, calc(100% - 40px)); margin: 0 auto; }
        .muted{ color: var(--muted); }
        .accent{ color: var(--accent); }
        .chip{
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 12px;
            border: 1px solid var(--border);
            background: var(--card);
            border-radius: 999px;
            backdrop-filter: blur(12px);
        }

        /* Nav */
        header{ position: sticky; top: 0; z-index: 50; }
        nav{
            height: 76px;
            border-bottom: 1px solid var(--border);
            background: rgba(10, 10, 30, 0.55);
            backdrop-filter: blur(12px);
        }
        [data-theme="light"] nav{ background: rgba(247, 247, 255, 0.75); }
        .nav-inner{
            height: 76px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 18px;
        }
        .brand{
            font-weight: 700;
            letter-spacing: 0.2px;
            display: flex;
            align-items: center;
            gap: 10px;
            white-space: nowrap;
        }
        .brand-dot{
            width: 10px;
            height: 10px;
            border-radius: 999px;
            background: linear-gradient(135deg, var(--accent), var(--accent2));
            box-shadow: 0 0 0 6px rgba(168, 85, 247, 0.15);
            animation: pulse-dot 2.8s ease-out infinite;
        }
        .nav-links{
            display: flex;
            gap: 18px;
            align-items: center;
            flex-wrap: wrap;
            justify-content: flex-end;
        }
        .nav-links a{
            padding: 10px 12px;
            border-radius: 10px;
            color: var(--muted);
            transition: transform 180ms ease, background 180ms ease, color 180ms ease;
        }
        .nav-links a:hover{
            color: var(--text);
            background: rgba(168, 85, 247, 0.12);
            transform: translateY(-1px);
        }
        .nav-links a.active{
            color: var(--text);
            background: rgba(34, 211, 238, 0.12);
            border: 1px solid var(--border);
        }
        .nav-actions{ display: flex; gap: 10px; align-items: center; }
        .icon-btn{
            border: 1px solid var(--border);
            background: var(--card);
            color: var(--text);
            border-radius: 12px;
            padding: 10px 12px;
            cursor: pointer;
            transition: transform 180ms ease, background 180ms ease;
            backdrop-filter: blur(12px);
        }
        .icon-btn:hover{ transform: translateY(-1px); background: rgba(255, 255, 255, 0.08); }

        /* Sections */
        section{ padding: 76px 0; scroll-margin-top: 90px; }
        .hero{
            padding-top: 80px;
            padding-bottom: 80px;
        }
        .hero-grid{
            display: grid;
            grid-template-columns: 1.25fr 0.75fr;
            gap: 34px;
            align-items: center;
        }
        .hero h1{
            font-size: clamp(2rem, 3vw + 1rem, 3.2rem);
            line-height: 1.12;
        }
        .hero p{
            margin-top: 14px;
            max-width: 62ch;
        }
        #element{ color: var(--accent); font-weight: 700; }
        .cta-row{
            margin-top: 22px;
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            align-items: center;
        }
        .btn{
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 12px 14px;
            border-radius: 14px;
            border: 1px solid var(--border);
            background: rgba(255, 255, 255, 0.07);
            color: var(--text);
            box-shadow: var(--shadow);
            transition: transform 180ms ease, background 180ms ease, border 180ms ease;
        }
        .btn:hover{ transform: translateY(-2px); background: rgba(168, 85, 247, 0.12); }
        .btn.primary{
            background: linear-gradient(135deg, rgba(168, 85, 247, 0.95), rgba(34, 211, 238, 0.75));
            border: 1px solid rgba(255, 255, 255, 0.22);
        }
        .btn.primary:hover{ background: linear-gradient(135deg, rgba(168, 85, 247, 1), rgba(34, 211, 238, 0.92)); }

        .hero-card{
            border: 1px solid var(--border);
            background: var(--card);
            border-radius: 18px;
            overflow: hidden;
            box-shadow: var(--shadow);
            position: relative;
            transform: translateZ(0);
        }
        .hero-card::before{
            content: "";
            position: absolute;
            inset: 0;
            background: radial-gradient(500px 300px at 20% 10%, rgba(168, 85, 247, 0.18), transparent 60%),
                        radial-gradient(480px 300px at 90% 40%, rgba(34, 211, 238, 0.12), transparent 55%);
            pointer-events: none;
        }
        .hero-card-inner{
            padding: 18px;
            position: relative;
            animation: float-soft 6s ease-in-out infinite alternate;
        }
        .avatar{
            border-radius: 16px;
            border: 1px solid var(--border);
            background: rgba(0, 0, 0, 0.18);
            box-shadow: 0 0 40px rgba(168, 85, 247, 0.55);
            transition: transform 220ms ease, box-shadow 220ms ease;
        }
        .hero-card:hover .avatar{
            transform: translateY(-4px) scale(1.02);
            box-shadow: 0 0 60px rgba(168, 85, 247, 0.78);
        }
        .hero-meta{
            margin-top: 12px;
            display: grid;
            gap: 10px;
        }

        .section-title{
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 18px;
            margin-bottom: 20px;
        }
        .section-title h2{
            font-size: 1.55rem;
            letter-spacing: 0.2px;
        }
        .grid{
            display: grid;
            gap: 14px;
        }
        .grid.two{ grid-template-columns: repeat(2, minmax(0, 1fr)); }
        .grid.three{ grid-template-columns: repeat(3, minmax(0, 1fr)); }

        .card{
            border: 1px solid var(--border);
            background: var(--card);
            border-radius: 18px;
            padding: 16px;
            box-shadow: var(--shadow);
            backdrop-filter: blur(12px);
            transition: transform 200ms ease, border 200ms ease, background 200ms ease;
        }
        .card:hover{
            transform: translateY(-4px);
            border-color: rgba(168, 85, 247, 0.35);
            background: rgba(255, 255, 255, 0.08);
        }
        .card h3{ font-size: 1.05rem; }
        .card p{ margin-top: 8px; color: var(--muted); }
        .tags{ margin-top: 12px; display: flex; flex-wrap: wrap; gap: 8px; }
        .tag{
            padding: 6px 10px;
            border-radius: 999px;
            border: 1px solid var(--border);
            background: rgba(255, 255, 255, 0.05);
            font-size: 0.85rem;
            color: var(--muted);
        }

        /* Contact */
        form{ display: grid; gap: 10px; }
        .field{
            display: grid;
            gap: 6px;
        }
        label{ font-size: 0.92rem; color: var(--muted); }
        input, textarea{
            border: 1px solid var(--border);
            background: rgba(255, 255, 255, 0.04);
            color: var(--text);
            padding: 12px 12px;
            border-radius: 14px;
            outline: none;
            font-family: inherit;
        }
        textarea{ min-height: 120px; resize: vertical; }
        input:focus, textarea:focus{ border-color: rgba(34, 211, 238, 0.55); }

        footer{
            padding: 28px 0 40px;
            border-top: 1px solid var(--border);
            color: var(--muted);
        }

        /* Reveal on scroll */
        .reveal{
            opacity: 0;
            transform: translateY(14px);
            transition: opacity 650ms ease, transform 650ms ease;
        }
        .reveal.visible{
            opacity: 1;
            transform: translateY(0);
        }

        /* Back to top */
        .to-top{
            position: fixed;
            right: 18px;
            bottom: 18px;
            opacity: 0;
            pointer-events: none;
            transform: translateY(6px);
            transition: opacity 180ms ease, transform 180ms ease;
        }
        .to-top.visible{
            opacity: 1;
            pointer-events: auto;
            transform: translateY(0);
        }

        @keyframes float-soft {
            0% { transform: translateY(0px); }
            50% { transform: translateY(-6px); }
            100% { transform: translateY(-2px); }
        }

        @keyframes pulse-dot {
            0% { box-shadow: 0 0 0 0 rgba(168, 85, 247, 0.40); }
            70% { box-shadow: 0 0 0 10px rgba(168, 85, 247, 0); }
            100% { box-shadow: 0 0 0 0 rgba(168, 85, 247, 0); }
        }

        @media (max-width: 900px){
            .hero-grid{ grid-template-columns: 1fr; }
            .grid.three{ grid-template-columns: 1fr; }
            .grid.two{ grid-template-columns: 1fr; }
            .nav-links{ display: none; }
        }

        @media (prefers-reduced-motion: reduce){
            html{ scroll-behavior: auto; }
            .card, .btn, .nav-links a, .icon-btn, .reveal{ transition: none !important; }
        }
    </style>
</head>

